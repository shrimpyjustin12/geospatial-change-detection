# Apptainer/Singularity definition for the change-detection training environment.
#
# Runtime on Leonardo: SingularityPRO 4.3.1 (`/usr/bin/singularity`) — this .def format
# is Apptainer-compatible. Base image is PyTorch 2.4.1 + CUDA 12.1 (cu121), which matches
# Leonardo's cuda/12.2 default (forward-compatible within CUDA 12.x on A100). See PRD §7.1.
#
# BUILD (on a login node — compute nodes have no egress):
#     singularity build --fakeroot container/changedet.sif container/changedet.def
#   If unprivileged --fakeroot builds are disallowed by the cluster policy, fall back to
#   pulling the base image and installing deps into an overlay (per leonardo.md); TODO:
#   confirm the site build policy before M1.
#
# VERIFY GPU stack INSIDE a Slurm job (never trust the login node — leonardo.md):
#     singularity exec --nv container/changedet.sif python -c \
#         "import torch; print(torch.__version__, torch.cuda.is_available())"

Bootstrap: docker
From: pytorch/pytorch:2.4.1-cuda12.1-cudnn9-runtime

%labels
    Maintainer sat-change-detection
    Description Change-detection training env (Track A aerial + Track B Sentinel-2). Torch 2.4.1 cu121.

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        git build-essential libgl1 libglib2.0-0 \
        && rm -rf /var/lib/apt/lists/*
    python -m pip install --no-cache-dir --upgrade pip
    # torch/torchvision already present in the base image (cu121). Add the CD + geo stack.
    python -m pip install --no-cache-dir \
        "torchgeo>=0.6" \
        "segmentation-models-pytorch>=0.3" \
        "timm>=1.0" \
        "transformers>=4.44" \
        "peft>=0.12" \
        "rasterio>=1.3" "rioxarray>=0.15" \
        "albumentations>=1.4" \
        "numpy<2.1" \
        "pyyaml>=6.0" \
        "tensorboard>=2.16" \
        "safetensors>=0.4"

%environment
    # Offline guards: compute nodes have no egress — never hit the network at train time.
    export HF_HUB_OFFLINE=1
    export TRANSFORMERS_OFFLINE=1
    export PYTHONNOUSERSITE=1
    export TOKENIZERS_PARALLELISM=false

%runscript
    exec python "$@"
